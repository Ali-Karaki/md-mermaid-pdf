{
	"name": "md-mermaid-pdf",
	"version": "0.1.1",
	"description": "Markdown to PDF with Mermaid diagrams via Puppeteer (builds on md-to-pdf).",
	"license": "MIT",
	"author": "Ali Karaki (https://github.com/Ali-Karaki)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Ali-Karaki/md-mermaid-pdf.git"
	},
	"homepage": "https://github.com/Ali-Karaki/md-mermaid-pdf#readme",
	"bugs": {
		"url": "https://github.com/Ali-Karaki/md-mermaid-pdf/issues"
	},
	"keywords": [
		"markdown",
		"pdf",
		"mermaid",
		"md-to-pdf",
		"puppeteer"
	],
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		}
	},
	"bin": {
		"md-mermaid-pdf": "bin/cli.js"
	},
	"files": [
		"lib",
		"bin"
	],
	"scripts": {
		"test": "node --test test/"
	},
	"engines": {
		"node": ">=20.16.0",
		"npm": ">=10.8.1"
	},
	"dependencies": {
		"get-port": "^5.1.1",
		"marked": "^4.3.0",
		"md-to-pdf": "^5.2.5",
		"mermaid": "^10.9.1",
		"puppeteer": ">=8.0.0"
	}
}
