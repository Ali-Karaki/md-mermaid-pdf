{
	"name": "md-mermaid-pdf",
	"version": "0.1.7",
	"description": "Markdown to PDF with Mermaid diagrams that actually render — drop-in replacement for md-to-pdf.",
	"license": "MIT",
	"author": "Ali Karaki (https://github.com/Ali-Karaki)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Ali-Karaki/md-mermaid-pdf.git"
	},
	"homepage": "https://md-mermaid-pdf-site-production.up.railway.app/",
	"bugs": {
		"url": "https://github.com/Ali-Karaki/md-mermaid-pdf/issues"
	},
	"keywords": [
		"markdown",
		"pdf",
		"mermaid",
		"mermaid-diagrams",
		"markdown-to-pdf",
		"docs-generator",
		"diagram-rendering",
		"md-to-pdf",
		"puppeteer"
	],
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"md-mermaid-pdf": "bin/cli.js",
		"mmdpdf": "bin/cli.js"
	},
	"files": [
		"lib",
		"bin",
		"presets"
	],
	"scripts": {
		"test": "node --test test/",
		"capture-readme-assets": "node scripts/capture-readme-assets.mjs"
	},
	"engines": {
		"node": ">=20.16.0",
		"npm": ">=10.8.1"
	},
	"dependencies": {
		"fast-glob": "^3.3.3",
		"get-port": "^5.1.1",
		"marked": "^4.3.0",
		"md-to-pdf": "^5.2.5",
		"mermaid": "^10.9.1",
		"puppeteer": ">=8.0.0"
	}
}
